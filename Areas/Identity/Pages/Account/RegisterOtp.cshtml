@page
@model RegisterOtpModel
@{
    ViewData["Title"] = "Verify registration OTP";
}

<div class="auth-shell">
    <div class="row g-4 justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 auth-card">
                <div class="card-body p-4">
                    <h1 class="h4 mb-2">@ViewData["Title"]</h1>
                    <p class="text-muted mb-4">Enter the OTP sent to <strong>@Model.Input.Email</strong> to activate your account.</p>

                    <form method="post" class="d-grid gap-3">
                        <input type="hidden" asp-for="Input.UserId" />
                        <input type="hidden" asp-for="Input.Email" />
                        <input type="hidden" asp-for="Input.ReturnUrl" />

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div>
                            <label asp-for="Input.Code" class="form-label"></label>
                            <input asp-for="Input.Code" class="form-control" autocomplete="one-time-code" />
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary">Verify OTP</button>
                    </form>

                    <form method="post" asp-page-handler="Resend" class="mt-3">
                        <input type="hidden" asp-for="Input.UserId" />
                        <input type="hidden" asp-for="Input.Email" />
                        <input type="hidden" asp-for="Input.ReturnUrl" />
                        <button type="submit" class="btn btn-outline-secondary w-100">Resend OTP</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
