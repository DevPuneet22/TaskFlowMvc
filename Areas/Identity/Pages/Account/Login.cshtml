@page
@model LoginModel
@{
    ViewData["Title"] = "Login";

    static string ProviderClass(string provider) => provider.ToLowerInvariant() switch
    {
        "google" => "btn btn-outline-danger w-100",
        "github" => "btn btn-dark w-100",
        "linkedin" => "btn btn-outline-primary w-100",
        _ => "btn btn-outline-secondary w-100"
    };
}

<div class="auth-shell">
    <div class="row g-4 justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-sm border-0 auth-card">
                <div class="card-body p-4 p-lg-5">
                    <div class="row g-4">
                        <div class="col-lg-6">
                            <h1 class="h3 mb-2">Welcome back</h1>
                            <p class="text-muted mb-4">Login to continue managing projects, teams, and tasks.</p>

                            <form id="account" method="post" class="d-grid gap-3">
                                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                                <div>
                                    <label asp-for="Input.Email" class="form-label"></label>
                                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" />
                                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                                </div>
                                <div>
                                    <label asp-for="Input.Password" class="form-label"></label>
                                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" />
                                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                                </div>
                                <div class="form-check">
                                    <input asp-for="Input.RememberMe" class="form-check-input" />
                                    <label asp-for="Input.RememberMe" class="form-check-label"></label>
                                </div>
                                <button id="login-submit" type="submit" class="btn btn-primary">Log in</button>
                                <div class="small d-grid gap-1">
                                    <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create a new account</a>
                                </div>
                            </form>
                        </div>

                        <div class="col-lg-6">
                            <div class="auth-aside h-100">
                                <h2 class="h5 mb-3">Login with social provider</h2>
                                @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                {
                                    <div class="alert alert-light border mb-0">
                                        No external authentication services are configured.
                                    </div>
                                }
                                else
                                {
                                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="d-grid gap-2">
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit" class="@ProviderClass(provider.Name)" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                                Continue with @provider.DisplayName
                                            </button>
                                        }
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
